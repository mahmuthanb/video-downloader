{
  "manifest_version": 3,
  "name": "VaultDL Helper",
  "version": "1.0",
  "description": "Aktif sekmedeki videoyu VaultDL indirme kuyruğuna ekle.",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
